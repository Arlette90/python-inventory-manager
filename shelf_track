import sqlite3

def q(sql, p=(), f=False):
    with sqlite3.connect("ebooksotrack.db") as c:
        c.execute("PRAGMA foreign_keys = ON;")
        cursor = c.execute(sql, p)
        return cursor.fetchall() if f else c.commit()
    
